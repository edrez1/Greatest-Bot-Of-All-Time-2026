language = "nodejs"
run = "npm start"
modules = ["nodejs-20"]

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 3055
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Status Server"

[[workflows.workflow]]
name = "Status Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 SETUP_KEY=devsetuptoken123456 node start.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
expertMode = true
