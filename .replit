language = "nodejs"
run = "npm start"
modules = ["nodejs-20"]

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 3055
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5000

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Status Server"

[[workflows.workflow]]
name = "Status Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node -e \"global.GoatBot={startTime:Date.now(),commands:new Map(),aliases:new Map(),eventCommands:new Map(),config:{nickNameBot:'Goat Bot 2026',prefix:'/',dashBoard:{port:5000}}}; global.db={allUserData:[],allThreadData:[]}; require('./dashboard/app.js')(null);\""

[agent]
expertMode = true
