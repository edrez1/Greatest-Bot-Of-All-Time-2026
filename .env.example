NODE_ENV=production
PORT=3001

# REQUIRED to actually log into Facebook (paste the JSON of your appstate cookie)
APPSTATE=
# Or, if your host mangles JSON env values, base64-encode the appstate and use this instead
APPSTATE_BASE64=

# Optional: only needed if you want auto cookie refresh
FB_EMAIL=
FB_PASSWORD=
FB_2FA=

# Optional: bot personality
BOT_NICKNAME=Goat Bot 2026
BOT_PREFIX=/
ADMIN_UIDS=

# Optional: MongoDB connection string (switches database.type to "mongodb" automatically)
MONGODB_URI=

# Optional: only needed if you want auto-uptime to ping a custom URL
UPTIME_URL=
